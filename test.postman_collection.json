              "});",
              "pm.test(\"Content-Type is present\", function () {",
              "    pm.response.to.have.header(\"Content-Type\", \"application/json; charset=utf-8\");",
              "});",
              "",
              "let response = pm.response.json()",
              "pm.environment.set(\"id\", response.id);"
